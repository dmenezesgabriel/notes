{
    "mcpServers": {
        "penpot": {
            "type": "http",
            "url": "http://localhost:4401/mcp"
        },
        "playwright": {
            "command": "npx",
            "args": [
                "@playwright/mcp@latest"
            ],
            "env": {
                "PLAYWRIGHT_MCP_HEADLESS": "1"
            }
        },
        "storybook": {
            "type": "http",
            "url": "http://localhost:6006/mcp"
        }
    }
}