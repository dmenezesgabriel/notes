{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "command": ["npx", "@playwright/mcp@latest"],
      "env": {
        "PLAYWRIGHT_MCP_HEADLESS": "1"
      },
      "enabled": true
    },
    "storybook": {
      "type": "http",
      "url": "http://localhost:6006/mcp",
      "enabled": true
    }
  }
}
