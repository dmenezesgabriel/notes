{
  "name": "notes",
  "type": "module",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "configs/*"
  ],
  "scripts": {
    "components:build": "pnpm -C packages/components build",
    "presite:dev": "pnpm components:build && pnpm content:build",
    "site:dev": "pnpm -C apps/site dev",
    "presite:build": "pnpm components:build && pnpm content:build",
    "site:build": "pnpm -C apps/site build",
    "storybook:dev": "pnpm -C apps/storybook dev",
    "storybook:build": "pnpm -C apps/storybook build",
    "content:build": "pnpm -C packages/content build",
    "build": "pnpm components:build && pnpm content:build && pnpm site:build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r run --if-present typecheck",
    "test": "pnpm -r run --if-present test",
    "prepare": "husky",
    "site:e2e": "pnpm -C apps/site e2e",
    "site:e2e:ci": "pnpm -C apps/site e2e:ci"
  },
  "devDependencies": {
    "@notes/eslint-config": "workspace:*",
    "@notes/prettier-config": "workspace:*",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "@dendronhq/dendron-cli": "0.120.0"
  }
}
